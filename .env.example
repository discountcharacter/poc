# Environment Configuration for Car Valuation Portal
# Copy this file to .env and fill in your actual values

# Google API Keys (for AI and Search features)
GOOGLE_API_KEY=your_gemini_api_key_here
GOOGLE_SEARCH_API_KEY=your_google_search_api_key_here
SEARCH_ENGINE_ID=your_search_engine_cx_id_here

# N8n Webhook URLs (for Cars24 Automation)
# Get these from your n8n workflow after creating it
# See n8n_workflow_guide.md for setup instructions
N8N_WEBHOOK_CAR_DETAILS=https://your-instance.app.n8n.cloud/webhook/car-details
N8N_WEBHOOK_OTP=https://your-instance.app.n8n.cloud/webhook/otp-verification

# Notes:
# - Replace all 'your_*_here' values with your actual credentials
# - Keep this file secure and never commit it to git (it's in .gitignore)
# - Restart Streamlit app after modifying this file
